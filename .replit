modules = ["python-3.12", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cargo", "gitFull", "libiconv", "playwright-driver", "rustc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python web_app.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "-w", "4", "--threads", "8", "--timeout", "120", "web_app:app"]

[userenv]

[userenv.shared]
FLASK_DEBUG = "0"
NO_BROWSER = "1"
FLASK_ENV = "production"
SECRET_KEY = "b07a160bfee713e0f0c41f030c6e61d3c6aecb298295d6be32e01cacb02a5a3b"
JWT_SECRET = "66dde1d43863d36cd8bf8cf285dfa1f6530ba451bdeccdd09838acd7814eec5f"
