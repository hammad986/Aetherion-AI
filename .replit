modules = ["python-3.12", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cargo", "gitFull", "libiconv", "playwright-driver", "rustc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python web_app.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "-w", "4", "--threads", "8", "--timeout", "120", "web_app:app"]

[userenv]

[userenv.shared]
FLASK_DEBUG = "0"
NO_BROWSER = "1"
FLASK_ENV = "production"
SECRET_KEY = "b20c39cb6de0a2d321cb6e5b0cde68cef7e9eccf7bdec7ecfc93ca9b60b493a6"
JWT_SECRET = "8b0acb9555dc7c53a5a794e44eac5eb1f26ae9f4c53c1be1428ff6ed051bb9b1"
