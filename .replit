modules = ["python-3.12", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cargo", "gitFull", "libiconv", "playwright-driver", "rustc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python web_app.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "-w", "4", "--threads", "8", "--timeout", "120", "web_app:app"]

[userenv]

[userenv.shared]
FLASK_DEBUG = "0"
NO_BROWSER = "1"
SECRET_KEY = "d479950e44a1511b88d9a2f16afa181b27b81cb660513743554ccbb194ac87f9"
JWT_SECRET = "fb6d7963c0bb6f05ccedd9a876088d703c9ee2a98bc8c3b9ba08f3c3dbc53c6e"
